#pattern 1
for i in range(1,6):
    for j in range(i):
        print("*",end="")
        print()

# pattern 2
for i in range(5,0,-1):
    for j in range(i):
        print("*",end="")
        print() 

#pattern 3
for i in range(5):
   for j in range(5-1):
       print(' ',end='')
   for k in range(i):
       print(k+1,end='')
    for l in range(i-1):
       print(i+l+1,end='')
       print()  
